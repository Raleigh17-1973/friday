# Friday web app (apps/web) environment variables
# Copy to apps/web/.env.local for local development.
# In Vercel, set these in: Project Settings → Environment Variables.

# Backend API URL — where the FastAPI server is running.
# Local dev: http://127.0.0.1:8000
# Production: https://friday-api.fly.dev  (your Fly.io app URL)
FRIDAY_BACKEND_URL=http://127.0.0.1:8000

# OpenAI API key for the /api/chatkit/session route (if using ChatKit SDK).
# Not required if you are only using the standard chat interface.
OPENAI_API_KEY=sk-proj-...
