# ─── Friday environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The API server auto-loads .env at startup — no need to `source` it.
# NEVER commit .env to git (it is in .gitignore).

# ─── LLM providers ────────────────────────────────────────────────────────────
# At least one must be set. Friday prefers Anthropic; falls back to OpenAI.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# ─── Database (optional — defaults to SQLite in ./data/) ──────────────────────
# Set these to use Postgres+pgvector for memory and audit storage.
# Format: postgresql://user:password@host:port/dbname
# Supabase example: postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Fly Postgres example: postgresql://friday:[password]@friday-db.flycast:5432/friday
FRIDAY_MEMORY_DATABASE_URL=
FRIDAY_AUDIT_DATABASE_URL=

# ─── API server ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# In production, set this to your Vercel deployment URL.
FRIDAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Secret key for admin-only endpoints (GET /admin/dashboard, etc.).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-me-in-production

# ─── Workflow engine (optional) ───────────────────────────────────────────────
# "inprocess" (default) runs workflows in the same process.
# "temporal" requires a running Temporal cluster (see infra/docker/docker-compose.yml).
FRIDAY_WORKFLOW_ENGINE=inprocess

# Temporal connection (only used when FRIDAY_WORKFLOW_ENGINE=temporal)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=friday-runs

# ─── Web app (apps/web) ───────────────────────────────────────────────────────
# Backend URL used by the Next.js server-side routes.
# In Vercel production, set this in the Vercel dashboard environment variables.
FRIDAY_BACKEND_URL=http://127.0.0.1:8000
